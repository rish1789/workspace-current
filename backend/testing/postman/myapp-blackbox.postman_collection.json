                  "pm.collectionVariables.set('tokenA', pm.response.json().token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login userB",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"userb_{{stamp}}@test.com\",\n  \"password\": \"Passw0rd!23\"\n}"
