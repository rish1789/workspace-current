              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('wrong password -> 401 (correct contract; currently returns 500)', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "02 - Access Control Negative",
      "item": [
        {
          "name": "Get workspaces without token -> 401/403",
          "request": {
            "method": "GET",
            "header": [],
            "url": { "raw": "{{baseUrl}}/api/workspaces/all", "host": ["{{baseUrl}}"], "path": ["api", "workspaces", "all"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('no token -> 401 or 403', () => pm.expect([401, 403]).to.include(pm.response.code));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "03 - Workspace",
      "item": [
        {
          "name": "Create workspace",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"workspaceName\": \"Workspace_{{stamp}}\"\n}" },
            "url": { "raw": "{{baseUrl}}/api/workspaces", "host": ["{{baseUrl}}"], "path": ["api", "workspaces"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('create workspace -> 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('workspaceId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Get workspace (owner) -> 200",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenA}}" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}", "host": ["{{baseUrl}}"], "path": ["api", "workspaces", "{{workspaceId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('owner gets workspace -> 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        },
        {
          "name": "Get workspace (non-member userB) -> 403/404",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }],
            "url": { "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}", "host": ["{{baseUrl}}"], "path": ["api", "workspaces", "{{workspaceId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": ["pm.test('non-member -> 403 or 404', () => pm.expect([403, 404]).to.include(pm.response.code));"]
              }
            }
          ]
        },
        {
          "name": "Add userB as workspace member",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{tokenA}}" }
            ],
            "body": { "mode": "raw", "raw": "{\n  \"userId\": {{userBId}},\n  \"role\": \"MEMBER\"\n}" },
            "url": {
              "raw": "{{baseUrl}}/api/workspaces/{{workspaceId}}/members",
              "host": ["{{baseUrl}}"],
              "path": ["api", "workspaces", "{{workspaceId}}", "members"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('add member -> 200', () => pm.response.to.have.status(200));"] }
            }
          ]
        }
      ]
    },
