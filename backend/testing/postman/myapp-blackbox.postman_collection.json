        },
        {
          "name": "userB views PRIVATE board after board membership -> 200",
          "request": {
            "method": "GET",
            "header": [{ "key": "Authorization", "value": "Bearer {{tokenB}}" }],
            "url": { "raw": "{{baseUrl}}/api/boards/{{boardId}}", "host": ["{{baseUrl}}"], "path": ["api", "boards", "{{boardId}}"] }
          },
          "event": [
            {
              "listen": "test",
              "script": { "type": "text/javascript", "exec": ["pm.test('board member -> 200', () => pm.response.to.have.status(200));"] }
