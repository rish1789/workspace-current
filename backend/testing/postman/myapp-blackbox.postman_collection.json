{
  "info": {
    "_postman_id": "8f2a1c40-6b1e-4e2a-9b0a-2f8e6c1a9d10",
    "name": "myapp Black-Box API Tests",
    "description": "Black-box functional tests for the myapp Trello-like backend. Treats the app purely as an HTTP API (no internal knowledge) and exercises the full Workspace -> Board -> Lane -> Card -> Checklist -> Comment -> Label lifecycle plus key access-control rules.\n\nRun order matters (Postman Runner / Collection Runner, top to bottom) since later requests depend on IDs and tokens captured by earlier ones.\n\nTwo tests are expected to FAIL against the current codebase on purpose, to surface known bugs:\n1. Login with wrong password returns 500 instead of 401.\n2. A non-author editing a comment returns 400 instead of 403.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "if (!pm.collectionVariables.get('stamp')) {",
          "    pm.collectionVariables.set('stamp', Date.now().toString());",
          "}"
        ]
      }
    }
  ],
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080" },
    { "key": "stamp", "value": "" },
    { "key": "tokenA", "value": "" },
    { "key": "tokenB", "value": "" },
    { "key": "userBId", "value": "" },
    { "key": "workspaceId", "value": "" },
    { "key": "boardId", "value": "" },
    { "key": "laneId", "value": "" },
    { "key": "cardId", "value": "" },
    { "key": "checklistId", "value": "" },
    { "key": "itemId", "value": "" },
    { "key": "commentId", "value": "" },
    { "key": "labelId", "value": "" }
  ],
  "item": [
    {
      "name": "01 - Auth",
      "item": [
        {
          "name": "Register userA",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"userA_{{stamp}}\",\n  \"email\": \"usera_{{stamp}}@test.com\",\n  \"password\": \"Passw0rd!23\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/register", "host": ["{{baseUrl}}"], "path": ["api", "users", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register userA -> 201', () => pm.response.to.have.status(201));",
                  "pm.test('response has id', () => pm.expect(pm.response.json().id).to.exist);"
                ]
              }
            }
          ]
        },
        {
          "name": "Register userB",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"userB_{{stamp}}\",\n  \"email\": \"userb_{{stamp}}@test.com\",\n  \"password\": \"Passw0rd!23\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/users/register", "host": ["{{baseUrl}}"], "path": ["api", "users", "register"] }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('register userB -> 201', () => pm.response.to.have.status(201));",
                  "pm.collectionVariables.set('userBId', pm.response.json().id);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login userA",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"usera_{{stamp}}@test.com\",\n  \"password\": \"Passw0rd!23\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/api/auth/login", "host": ["{{baseUrl}}"], "path": ["api", "auth", "login"] }
          },
          "event": [
            {
              "listen": "test",
