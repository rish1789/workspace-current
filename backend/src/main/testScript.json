    {
      "name": "01 - Users",
      "item": [
        {
          "name": "Create User 1",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('userId', pm.response.json().userId);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\":\"Rishabh\",\"email\":\"rishabh@example.com\",\"password\":\"Pass@1234\"}" }
          }
        },
        {
          "name": "Create User 2",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 201', () => pm.response.to.have.status(201));",
            "pm.collectionVariables.set('userId2', pm.response.json().userId);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\":\"Rohan\",\"email\":\"rohan@example.com\",\"password\":\"Pass@1234\"}" }
          }
        },
        {
          "name": "Get User By ID",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Has userId', () => pm.expect(pm.response.json()).to.have.property('userId'));"
          ]}}],
          "request": {
            "method": "GET", "url": "{{baseUrl}}/users/{{userId}}"
          }
        },
        {
          "name": "Get User By Email",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "GET", "url": "{{baseUrl}}/users/email/rishabh@example.com"
          }
        },
        {
          "name": "Update Username",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/users/{{userId}}/username",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\":\"Rishabh Yadav\"}" }
          }
        },
        {
          "name": "Update Email",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));"
          ]}}],
          "request": {
            "method": "PATCH", "url": "{{baseUrl}}/users/{{userId}}/email",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"rishabh.yadav@example.com\"}" }
          }
        },
        {
          "name": "Validate Login - Valid",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Login valid', () => pm.expect(pm.response.json()).to.be.true);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/users/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"rishabh.yadav@example.com\",\"password\":\"Pass@1234\"}" }
          }
        },
        {
          "name": "Validate Login - Invalid",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 200', () => pm.response.to.have.status(200));",
            "pm.test('Login invalid', () => pm.expect(pm.response.json()).to.be.false);"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/users/login",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"email\":\"rishabh.yadav@example.com\",\"password\":\"WrongPass@1\"}" }
          }
        },
        {
          "name": "Create Duplicate User - Expect 400",
          "event": [{ "listen": "test", "script": { "exec": [
            "pm.test('Status 400', () => pm.response.to.have.status(400));"
          ]}}],
          "request": {
            "method": "POST", "url": "{{baseUrl}}/users",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\"username\":\"Rishabh\",\"email\":\"rishabh.yadav@example.com\",\"password\":\"Pass@1234\"}" }
          }
        }
